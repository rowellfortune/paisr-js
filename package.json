{
  "name": "paisr-js",
  "version": "0.3.1",
  "description": "Typed JavaScript/TypeScript client for the Paisr API",
  "type": "module",
  "license": "MIT",
  "author": "rowellfortune",
  "homepage": "https://github.com/rowellfortune/paisr-js#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rowellfortune/paisr-js.git"
  },
  "bugs": {
    "url": "https://github.com/rowellfortune/paisr-js/issues"
  },
  "keywords": [
    "paisr",
    "sdk",
    "api-client",
    "wallets",
    "payments",
    "typescript"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "generate": "openapi-typescript src/spec/paisr.yaml -o src/generated/types.ts",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "axios": "^1.18.1"
  },
  "devDependencies": {
    "openapi-typescript": "^7.4.3",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=18"
  }
}
